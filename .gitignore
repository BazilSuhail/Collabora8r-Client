# dependencies
/node_modules
/.pnp
.pnp.js
/dist

# testing
/coverage

# production
/build

# misc
.DS_Store
.env.local
.env.development.local
.env
package-lock.json
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.bat
*.txt
*.lock
# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Ignore ALL markdown files except README.md and those in /docs
*.md
!README.md
!docs/**/*.md
